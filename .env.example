# Environment Variables for Enhanced RAG System
# Copy this to .env and fill in your values

# Confluence Integration (Optional)
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-confluence-api-token-here
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=your-email@yourcompany.com

# Alternative Confluence Authentication Methods
# Use ONE of the following instead of API token:

# Personal Access Token (for Server/Data Center)
# CONFLUENCE_PAT=your-personal-access-token

# Basic Auth (not recommended for production)
# CONFLUENCE_PASSWORD=your-confluence-password

# Optional: Logging Configuration
LOG_LEVEL=INFO
DEBUG_MODE=false

# Optional: Performance Tuning
MAX_WORKERS=4
CRAWL_DELAY=1.0
MAX_PAGES=100

# Optional: Database Configuration (if using external DB)
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5432
# PGVECTOR_DB=ragdb
# PGVECTOR_USER=raguser
# PGVECTOR_PASSWORD=ragpassword

# Optional: LlamaStack Configuration (if using external instance)
# LLAMASTACK_URL=http://localhost:8321

# Usage Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. The docker-compose.yml will automatically load these variables
# 4. Never commit .env to version control (it's in .gitignore)