# OpenAI Configuration for RAG on PC
# Copy this to .env and fill in your values

# Required: OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Models (recommended for cost/performance)
INFERENCE_MODEL=gpt-4o-mini              # Cheap and fast for chat
EMBEDDING_MODEL=text-embedding-3-small   # Good quality embeddings

# Optional: Confluence Integration
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL=https://your-company.atlassian.net
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# Optional: Web Search (get from https://tavily.com)
TAVILY_SEARCH_API_KEY=your-tavily-api-key

# Advanced: Alternative OpenAI Models
# INFERENCE_MODEL=gpt-4o                    # Higher quality, more expensive
# INFERENCE_MODEL=gpt-3.5-turbo            # Cheaper alternative
# EMBEDDING_MODEL=text-embedding-3-large   # Higher quality embeddings